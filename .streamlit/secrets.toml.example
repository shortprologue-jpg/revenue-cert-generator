# ── Streamlit secrets 예시 ──────────────────────────────────────────────
# 로컬에서 secrets 로 테스트하려면: 이 파일을 복사해 .streamlit/secrets.toml 로 저장하고
#   실제 값을 채우세요. (실제 secrets.toml 은 .gitignore 로 이미 커밋 제외됨.)
# 배포(Streamlit Cloud)에선: 이 내용을 "앱 설정 > Secrets" 칸에 붙여넣습니다.
#
# 참고: 로컬에선 secrets.toml 없이 .env 만 써도 됩니다(둘 다 지원). Supabase 두 줄을
#       비우거나 지우면 보관함이 자동으로 로컬 파일(outputs/) 저장으로 동작합니다.

NOTION_API_KEY = "ntn_여기에_노션_키"
GEMINI_API_KEY = "AIza_여기에_제미나이_키"

# 웹 배포 저장소(Supabase) — 있으면 보관함을 인터넷 창고에 저장.
